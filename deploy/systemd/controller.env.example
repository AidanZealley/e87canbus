# Installed as /etc/e87canbus/controller.env and readable by root/e87canbus only.
E87CANBUS_PROFILE=car
E87CANBUS_PORT=8000
E87CANBUS_DATABASE=/var/lib/e87canbus/application.sqlite3
# api.main constructs its ASGI app during import, before the CLI processes --profile-database.
# Keep the import-time database path on the service's writable application database as well.
E87CANBUS_PROFILE_DATABASE=/var/lib/e87canbus/application.sqlite3
E87CANBUS_FRONTEND=/opt/e87canbus/frontend/dist

# The selected deployment profile owns device sources, network enablement, TX grants,
# and development API capabilities. Do not add per-device overrides here.
