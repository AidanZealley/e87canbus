# Installed as /etc/e87canbus/controller.env and readable by root/e87canbus only.
E87CANBUS_PORT=8000
E87CANBUS_DATABASE=/var/lib/e87canbus/application.sqlite3
E87CANBUS_FRONTEND=/opt/e87canbus/frontend/dist

# CAN network configuration for live mode.
# The application does not create CAN interfaces - every enabled interface must already exist.
# Disabled networks are not opened. TX grants are independent from interface enablement.
#
# Initial bench configuration (single K-CAN interface on can0):
E87CANBUS_ENABLED_NETWORKS=kcan
E87CANBUS_TX_NETWORKS=kcan
#
# Full three-network configuration (requires can0, can1, can2 to exist):
# E87CANBUS_ENABLED_NETWORKS=kcan,ptcan,fcan
# E87CANBUS_TX_NETWORKS=kcan
#
# PT-CAN and F-CAN TX grants require a separate explicit decision.
